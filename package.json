{
  "name": "folia-major",
  "productName": "Folia",
  "description": "Lyrics Reimagine",
  "author": {
    "name": "chthollyphile",
    "email": "chthollyphile@users.noreply.github.com"
  },
  "private": true,
  "version": "0.6.1",
  "license": "AGPL-3.0",
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:vercel-api && vite build",
    "build:vercel-api": "tsc -p api-ts/tsconfig.json",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run -c vitest.config.ts",
    "test:unit": "vitest run -c vitest.config.ts",
    "test:unit:watch": "vitest -c vitest.config.ts",
    "test:ui": "playwright test",
    "test:ui:update": "playwright test --update-snapshots",
    "benchmark:lyrics": "npx tsx test/manual/lyrics_benchmark.ts",
    "manual:lyrics": "npx tsx test/manual/netease_lyrics_cli.ts",
    "audit:lyrics-sources": "npx tsx test/manual/lyric-audit/index.ts",
    "probe:netease-xeapi": "node test/manual/netease_xeapi_probe.cjs",
    "stage:client": "vite --open /stage-client.html",
    "dev:electron": "cross-env ELECTRON_DEV=true concurrently -k \"vite\" \"wait-on tcp:3000 && electron .\"",
    "dev:electron:dist": "cross-env ELECTRON_DEV=false ELECTRON=true ELECTRON_LINUX_PACKAGED_GRAPHICS=true vite build && electron .",
    "dev:electron:dist:swiftshader": "cross-env ELECTRON_DEV=false ELECTRON=true ELECTRON_LINUX_PACKAGED_GRAPHICS=true FOLIA_LINUX_GRAPHICS_MODE=swiftshader vite build && electron .",
    "dev:electron:dist:software": "cross-env ELECTRON_DEV=false ELECTRON=true ELECTRON_LINUX_PACKAGED_GRAPHICS=true FOLIA_LINUX_GRAPHICS_MODE=software vite build && electron .",
    "build:electron:dir": "cross-env ELECTRON_DEV=false ELECTRON=true vite build && electron-builder --linux dir",
    "build:electron": "cross-env ELECTRON_DEV=false ELECTRON=true vite build && electron-builder",
    "contributors:add": "npx all-contributors-cli add",
    "contributors:generate": "npx all-contributors-cli generate"
  },
  "build": {
    "appId": "top.izuna.foliamajor",
    "productName": "Folia",
    "generateUpdatesFilesForAllChannels": true,
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "chthollyphile",
        "repo": "folia-major"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "shared/**/*",
      "package.json",
      "build/miao.png",
      "build/thumbar/*.png"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/icon.png",
        "to": "linux/icon.png"
      },
      {
        "from": "build/trayTemplate.png",
        "to": "trayTemplate.png"
      },
      {
        "from": "build/trayTemplate@2x.png",
        "to": "trayTemplate@2x.png"
      },
      {
        "from": "packaging/linux/folia-major.desktop",
        "to": "linux/folia-major.desktop"
      },
      {
        "from": "packaging/linux/README-LINUX.txt",
        "to": "linux/README-LINUX.txt"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "artifactName": "${name}-${version}-linux-${arch}.${ext}",
      "target": [
        "dir"
      ],
      "publish": {
        "provider": "github",
        "publishAutoUpdate": false
      },
      "icon": "build/icon.png",
      "category": "AudioVideo",
      "executableName": "folia-major"
    }
  },
  "dependencies": {
    "@applemusic-like-lyrics/ttml": "^1.0.1",
    "@chenglou/pretext": "^0.0.8",
    "@google/genai": "^2.12.0",
    "@neteasecloudmusicapienhanced/api": "^4.36.2",
    "@paper-design/shaders-react": "^0.0.77",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@xhayper/discord-rpc": "^1.3.4",
    "@xmldom/xmldom": "^0.9.10",
    "axios": "^1.18.1",
    "blueimp-md5": "^2.19.0",
    "buffer": "^6.0.3",
    "busboy": "^1.6.0",
    "dexie": "^4.4.4",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "fflate": "^0.8.3",
    "framer-motion": "^12.42.2",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.25.0",
    "music-metadata": "^11.14.0",
    "opencc-js": "^1.4.1",
    "react": "^19.2.7",
    "react-colorful": "^5.8.0",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.10",
    "react-window": "^2.2.7",
    "three": "^0.185.1",
    "twgl.js": "^7.0.0",
    "wanakana": "^5.3.1",
    "ws": "^8.21.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@emnapi/core": "1.11.2",
    "@emnapi/runtime": "1.11.2",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/blueimp-md5": "^2.18.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.4",
    "baseline-browser-mapping": "^2.10.43",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "fake-indexeddb": "^6.2.5",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.3",
    "typescript": "~7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "@discordjs/rest": {
      "undici": "^6.27.0"
    }
  }
}
